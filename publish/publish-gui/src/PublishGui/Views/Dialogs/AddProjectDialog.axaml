<Window x:Class="PublishGui.Views.Dialogs.AddProjectDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加项目"
        Width="500"
        Height="400"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="添加已有项目" FontWeight="Bold" FontSize="16" />

        <TextBlock Text="项目名称" />
        <TextBox x:Name="ProjectNameBox" Watermark="输入项目名称" />

        <TextBlock Text="服务端地址" />
        <TextBox x:Name="ServerUrlBox" Watermark="例如: http://localhost:2000" />

        <TextBlock Text="本地路径" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="LocalPathBox" Watermark="选择项目本地路径" Width="300" />
            <Button Content="浏览..." x:Name="BrowseButton" />
        </StackPanel>

        <TextBlock Text="项目 ID（可选，已 init 的项目填写）" />
        <TextBox x:Name="ProjectIdBox" Watermark="0" />

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" x:Name="CancelButton" Classes="Tertiary" />
            <Button Content="确认添加" x:Name="ConfirmButton" Classes="Primary" />
        </StackPanel>
    </StackPanel>
</Window>
