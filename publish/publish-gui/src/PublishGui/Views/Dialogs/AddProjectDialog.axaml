<Window x:Class="PublishGui.Views.Dialogs.AddProjectDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        Title="Add Project"
        Width="480" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SemiColorBg0}"
        CanResize="False">
    <Grid RowDefinitions="*,Auto" Margin="24,20">
        <StackPanel Spacing="16">
            <!-- Server URL -->
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                    <materialIcons:MaterialIcon Kind="Server" Width="14" Height="14"
                                                 Foreground="{DynamicResource SemiColorText1}"/>
                    <TextBlock Text="Server URL" FontWeight="Medium" FontSize="13"
                               Foreground="{DynamicResource SemiColorText0}"/>
                </StackPanel>
                <TextBox Name="ServerUrlBox" Watermark="http://localhost:2000" FontSize="13"/>
            </StackPanel>

            <!-- Project Name -->
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                    <materialIcons:MaterialIcon Kind="FileDocumentOutline" Width="14" Height="14"
                                                 Foreground="{DynamicResource SemiColorText1}"/>
                    <TextBlock Text="Project Name" FontWeight="Medium" FontSize="13"
                               Foreground="{DynamicResource SemiColorText0}"/>
                </StackPanel>
                <TextBox Name="ProjectNameBox" Watermark="e.g. MyApp" FontSize="13"/>
            </StackPanel>

            <!-- Local Path -->
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                    <materialIcons:MaterialIcon Kind="FolderOutline" Width="14" Height="14"
                                                 Foreground="{DynamicResource SemiColorText1}"/>
                    <TextBlock Text="Local Path" FontWeight="Medium" FontSize="13"
                               Foreground="{DynamicResource SemiColorText0}"/>
                </StackPanel>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Name="ProjectPathBox"
                             Watermark="C:\Projects\MyApp\build" FontSize="13"/>
                    <Button Grid.Column="1" Name="BrowseBtn" Content="Browse..."
                            Margin="8,0,0,0" Height="32" Padding="12,0"/>
                </Grid>
            </StackPanel>

            <!-- Project ID -->
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                    <materialIcons:MaterialIcon Kind="Identifier" Width="14" Height="14"
                                                 Foreground="{DynamicResource SemiColorText1}"/>
                    <TextBlock Text="Project ID" FontWeight="Medium" FontSize="13"
                               Foreground="{DynamicResource SemiColorText0}"/>
                </StackPanel>
                <TextBox Name="ProjectIdBox" Text="0" FontSize="13"/>
                <TextBlock Text="Leave 0 to auto-lookup by name from server."
                           FontSize="11" Margin="0,4,0,0"
                           Foreground="{DynamicResource SemiColorText3}"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8"
                    Margin="0,20,0,0">
            <Button Name="CancelBtn" Content="Cancel" Height="32" Padding="16,0"/>
            <Button Name="ConfirmBtn" Content="Add Project"
                    Classes="Primary" Height="32" Padding="16,0"/>
        </StackPanel>
    </Grid>
</Window>
