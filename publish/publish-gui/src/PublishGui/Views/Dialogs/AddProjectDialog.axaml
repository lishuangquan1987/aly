<Window x:Class="PublishGui.Views.Dialogs.AddProjectDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        Title="添加项目"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SemiColorBg0}"
        CanResize="False">
    <Grid RowDefinitions="*,Auto" Margin="24,20">
        <ScrollViewer>
            <StackPanel Spacing="16">
                <!-- Server URL + 获取项目 -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Kind="Server" Width="14" Height="14"
                                                     Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Text="服务端地址" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Name="ServerUrlBox" Watermark="http://localhost:2000" FontSize="13"/>
                        <Button Grid.Column="1" Name="FetchProjectsBtn" Content="获取项目"
                                Margin="8,0,0,0" Height="32" Padding="12,0"
                                Classes="Primary"/>
                    </Grid>
                </StackPanel>

                <!-- 服务端项目列表 -->
                <StackPanel Name="ProjectListPanel" IsVisible="False">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Kind="FormatListBulleted" Width="14" Height="14"
                                                     Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Text="选择服务端项目" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </StackPanel>
                    <Border BorderBrush="{DynamicResource SemiColorBorder}"
                            BorderThickness="1" CornerRadius="6" MaxHeight="150">
                        <ListBox Name="ServerProjectList" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,6" Margin="0,1" CornerRadius="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource SemiColorText0}"/>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource SemiColorText2}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,2,0,0">
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText3}">
                                                    <Run Text="ID: "/>
                                                    <Run Text="{Binding Id}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText3}">
                                                    <Run Text="版本: "/>
                                                    <Run Text="{Binding Version}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>

                <!-- 获取状态 / 空结果提示 -->
                <StackPanel Name="FetchStatusPanel" IsVisible="False" Spacing="6">
                    <TextBlock Name="FetchStatusText" FontSize="12"
                               Foreground="{DynamicResource SemiColorText2}"/>
                    <Button Name="CreateOnServerBtn" Content="在服务端新建项目"
                            IsVisible="False" Height="32" Padding="12,0"
                            Classes="Tertiary"/>
                </StackPanel>

                <!-- Project Name -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Kind="FileDocumentOutline" Width="14" Height="14"
                                                     Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Text="项目名称" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </StackPanel>
                    <TextBox Name="ProjectNameBox" Watermark="例如 MyApp" FontSize="13"/>
                </StackPanel>

                <!-- Local Path -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Kind="FolderOutline" Width="14" Height="14"
                                                     Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Text="本地路径" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Name="ProjectPathBox"
                                 Watermark="C:\Projects\MyApp\build" FontSize="13"/>
                        <Button Grid.Column="1" Name="BrowseBtn" Content="浏览..."
                                Margin="8,0,0,0" Height="32" Padding="12,0"/>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8"
                    Margin="0,20,0,0">
            <Button Name="CancelBtn" Content="取消" Height="32" Padding="16,0"/>
            <Button Name="ConfirmBtn" Content="添加项目"
                    Classes="Primary" Height="32" Padding="16,0"/>
        </StackPanel>
    </Grid>
</Window>
