<Window x:Class="PublishGui.Views.Dialogs.ProjectSettingsDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="项目设置"
        Width="500"
        Height="450"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="项目设置" FontWeight="Bold" FontSize="16" />

        <TextBlock Text="项目名称" />
        <TextBox x:Name="ProjectNameBox" Watermark="项目名称" />

        <TextBlock Text="服务端地址" />
        <TextBox x:Name="ServerUrlBox" Watermark="例如: http://localhost:2000" />

        <TextBlock Text="本地路径" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="LocalPathBox" Watermark="项目本地路径" Width="300" />
            <Button Content="浏览..." x:Name="BrowseButton" />
        </StackPanel>

        <TextBlock Text="项目 ID" />
        <TextBox x:Name="ProjectIdBox" Watermark="0" />

        <TextBlock Text="publish-cli 路径" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="CliPathBox" Watermark="publish-cli.exe 路径" Width="300" />
            <Button Content="浏览..." x:Name="BrowseCliButton" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" x:Name="CancelButton" Classes="Tertiary" />
            <Button Content="保存" x:Name="SaveButton" Classes="Primary" />
        </StackPanel>
    </StackPanel>
</Window>
