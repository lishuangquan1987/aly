<Window x:Class="ZapPublish.Views.Dialogs.AddLocalProjectDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZapPublish.ViewModels"
        x:DataType="vm:AddLocalProjectDialogViewModel"
        Title="添加本地项目"
        Width="520" Height="260"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SemiColorBg0}">
    <Grid RowDefinitions="*,Auto" Margin="20,16">
        <StackPanel Spacing="12">
            <TextBlock Text="选择已初始化的本地项目文件夹" FontSize="14"
                       Foreground="{DynamicResource SemiColorText0}"/>
            <TextBlock Text="文件夹内必须包含 .updator/shared.json 配置文件" FontSize="12"
                       Foreground="{DynamicResource SemiColorText2}"/>

            <Grid ColumnDefinitions="*,Auto" Height="30">
                <TextBox Text="{Binding ProjectPath}"
                         Watermark="选择项目文件夹..."
                         VerticalContentAlignment="Center" FontSize="13"/>
                <Button Grid.Column="1" Command="{Binding BrowseCommand}"
                        Content="浏览" Margin="8,0,0,0" Height="30" Padding="16,0"/>
            </Grid>

            <TextBlock Text="{Binding InitStatusMessage}" FontSize="12"
                       Foreground="{DynamicResource SemiColorText2}"
                       IsVisible="{Binding ShowInitStatus}"/>

            <Grid ColumnDefinitions="Auto,*" Height="30" IsVisible="{Binding ShowInitStatus}">
                <TextBlock Text="显示名称" VerticalAlignment="Center"
                           FontSize="13" Margin="0,0,10,0"
                           Foreground="{DynamicResource SemiColorText1}"/>
                <TextBox Grid.Column="1" Text="{Binding DisplayName}"
                         Watermark="自动从配置读取"
                         VerticalContentAlignment="Center" FontSize="13"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Command="{Binding CancelCommand}" Content="取消"
                    Height="32" Padding="20,0"/>
            <Button Command="{Binding ConfirmCommand}" Content="添加项目"
                    Classes="Primary" Height="32" Padding="20,0"/>
        </StackPanel>
    </Grid>
</Window>
