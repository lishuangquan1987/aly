<Window x:Class="ZapPublish.Views.Dialogs.AddProjectDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZapPublish.ViewModels"
        xmlns:cli="using:ZapPublish.Models.Cli"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:DataType="vm:AddProjectDialogViewModel"
        Title="添加项目"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SemiColorBg0}"
        CanResize="False">
    <Grid RowDefinitions="*,Auto" Margin="24,20">
        <ScrollViewer>
            <StackPanel Spacing="16">
                <!-- Server URL + 获取项目 -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Kind="Server" Width="14" Height="14"
                                                     Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Text="服务端地址" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding ServerUrl}" Watermark="http://localhost:2000" FontSize="13"/>
                        <Button Grid.Column="1" Command="{Binding FetchProjectsCommand}"
                                Content="获取项目"
                                Margin="8,0,0,0" Height="32" Padding="12,0"
                                Classes="Primary"/>
                    </Grid>
                </StackPanel>

                <!-- 服务端项目列表 -->
                <StackPanel IsVisible="{Binding ShowProjectList}">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Kind="FormatListBulleted" Width="14" Height="14"
                                                     Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Text="选择服务端项目" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </StackPanel>
                    <Border BorderBrush="{DynamicResource SemiColorBorder}"
                            BorderThickness="1" CornerRadius="6" MaxHeight="150">
                        <ListBox ItemsSource="{Binding ServerProjects}"
                                 SelectedItem="{Binding SelectedServerProject}"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="cli:ProjectInfo">
                                    <Border Padding="10,6" Margin="0,1" CornerRadius="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource SemiColorText0}"/>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource SemiColorText2}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,2,0,0">
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText3}">
                                                    <Run Text="ID: "/>
                                                    <Run Text="{Binding Id}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText3}">
                                                    <Run Text="版本: "/>
                                                    <Run Text="{Binding Version}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>

                <!-- 获取状态 / 空结果提示 -->
                <StackPanel IsVisible="{Binding ShowCreateButton}" Spacing="6">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource SemiColorText2}"/>
                    <Button Command="{Binding CreateOnServerCommand}"
                            Content="在服务端新建项目"
                            Height="32" Padding="12,0"
                            Classes="Tertiary"/>
                </StackPanel>

                <!-- Display Name -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Kind="FileDocumentOutline" Width="14" Height="14"
                                                     Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Text="显示名称" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </StackPanel>
                    <TextBox Text="{Binding DisplayName}"
                             Watermark="例如 MyApp（本地别名，可自定义）" FontSize="13"/>
                </StackPanel>

                <!-- Local Path -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Kind="FolderOutline" Width="14" Height="14"
                                                     Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Text="本地路径" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding ProjectPath}"
                                 Watermark="C:\Projects\MyApp\build" FontSize="13"/>
                        <Button Grid.Column="1" Command="{Binding BrowseCommand}"
                                Content="浏览..."
                                Margin="8,0,0,0" Height="32" Padding="12,0"/>
                    </Grid>
                </StackPanel>

                <!-- 初始化状态 -->
                <StackPanel IsVisible="{Binding ShowInitStatus}" Spacing="6">
                    <TextBlock Text="{Binding InitStatusMessage}" FontSize="12"
                               Foreground="{DynamicResource SemiColorText2}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8"
                    Margin="0,20,0,0">
            <Button Command="{Binding CancelCommand}" Content="取消" Height="32" Padding="16,0"/>
            <Button Command="{Binding ConfirmCommand}" Content="添加项目"
                    Classes="Primary" Height="32" Padding="16,0"/>
        </StackPanel>
    </Grid>
</Window>
