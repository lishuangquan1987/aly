<Window x:Class="ZapPublish.Views.Dialogs.CreateProjectDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZapPublish.ViewModels"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:DataType="vm:CreateProjectDialogViewModel"
        Title="在服务端新建项目"
        Width="480" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SemiColorBg0}"
        CanResize="False">
    <Grid RowDefinitions="*,Auto" Margin="24,20">
        <ScrollViewer>
            <StackPanel Spacing="16">
                <!-- 项目名称 -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="FileDocumentOutline"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="项目名称"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                        <TextBlock Grid.Column="2" Text="*"
                                   Foreground="{DynamicResource SemiColorDanger}" FontSize="13"/>
                    </Grid>
                    <TextBox Text="{Binding ProjectName}"
                             Watermark="例如 myapp（唯一标识，不可修改）" FontSize="13"/>
                </StackPanel>

                <!-- 项目标题 -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="TextBoxOutline"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="项目标题"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                        <TextBlock Grid.Column="2" Text="*"
                                   Foreground="{DynamicResource SemiColorDanger}" FontSize="13"/>
                    </Grid>
                    <TextBox Text="{Binding ProjectTitle}"
                             Watermark="例如 我的应用（显示名称）" FontSize="13"/>
                </StackPanel>

                <!-- 强制更新 -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="AlertCircleOutline"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="强制更新"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </Grid>
                    <CheckBox IsChecked="{Binding ForceUpdate}"
                              Content="客户端检测到新版本时强制更新（跳过用户确认）"
                              FontSize="12"/>
                </StackPanel>

                <!-- 忽略文件夹 -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="FolderRemoveOutline"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="忽略文件夹"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </Grid>
                    <TextBox Text="{Binding IgnoreFolders}"
                             Watermark="多个文件夹用逗号分隔，例如 logs,temp,cache"
                             FontSize="13" AcceptsReturn="True" MinHeight="40"
                             TextWrapping="Wrap"/>
                    <TextBlock Text="扫描文件时将跳过这些文件夹，不参与版本管理。"
                               FontSize="11" Margin="0,4,0,0"
                               Foreground="{DynamicResource SemiColorText3}"/>
                </StackPanel>

                <!-- 忽略文件 -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="FileRemoveOutline"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="忽略文件"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </Grid>
                    <TextBox Text="{Binding IgnoreFiles}"
                             Watermark="多个文件用逗号分隔，例如 .DS_Store,Thumbs.db,*.log"
                             FontSize="13" AcceptsReturn="True" MinHeight="40"
                             TextWrapping="Wrap"/>
                    <TextBlock Text="扫描文件时将跳过这些文件，不参与版本管理。"
                               FontSize="11" Margin="0,4,0,0"
                               Foreground="{DynamicResource SemiColorText3}"/>
                </StackPanel>

                <!-- 状态提示 -->
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource SemiColorText2}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,20,0,0">
            <TextBlock Grid.Column="0" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Command="{Binding CancelCommand}" Content="取消"
                    Height="32" Padding="16,0" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Command="{Binding CreateCommand}" Content="创建项目"
                    Classes="Primary" Height="32" Padding="16,0"/>
        </Grid>
    </Grid>
</Window>
