<Window
    Background="{DynamicResource SemiColorBg0}"
    CanResize="False"
    Height="500"
    Title="编辑项目"
    Width="520"
    WindowStartupLocation="CenterOwner"
    x:Class="AlyPublish.Views.Dialogs.EditProjectDialog"
    x:DataType="vm:EditProjectDialogViewModel"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:sys="using:System"
    xmlns:vm="using:AlyPublish.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24,20" RowDefinitions="*,Auto">

        <!--  Loading overlay  -->
        <Border
            Background="#80000000"
            Grid.RowSpan="2"
            IsVisible="{Binding IsBusy}"
            ZIndex="100">
            <StackPanel
                HorizontalAlignment="Center"
                Spacing="12"
                VerticalAlignment="Center">
                <ProgressBar
                    Foreground="{DynamicResource SemiColorPrimary}"
                    Height="4"
                    IsIndeterminate="True"
                    Width="160" />
                <TextBlock
                    FontSize="13"
                    Foreground="White"
                    Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>

        <ScrollViewer>
            <StackPanel Spacing="16">

                <!--  GUI 配置  -->
                <Border
                    Background="{DynamicResource SemiColorBg1}"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel Margin="14,12" Spacing="10">
                        <Grid ColumnDefinitions="Auto,*">
                            <materialIcons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText1}"
                                Grid.Column="0"
                                Height="14"
                                Kind="Monitor"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Width="14" />
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource SemiColorText0}"
                                Grid.Column="1"
                                Text="GUI 配置"
                                VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel>
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource SemiColorText2}"
                                Margin="0,0,0,4"
                                Text="显示名称" />
                            <TextBox FontSize="13" Text="{Binding DisplayName}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  CLI 配置 (.updator/)  -->
                <Border
                    Background="{DynamicResource SemiColorBg1}"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel Margin="14,12" Spacing="10">
                        <Grid ColumnDefinitions="Auto,*">
                            <materialIcons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText1}"
                                Grid.Column="0"
                                Height="14"
                                Kind="Cog"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Width="14" />
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource SemiColorText0}"
                                Grid.Column="1"
                                Text="项目配置 (.updator/) — 通过 CLI 修改"
                                VerticalAlignment="Center" />
                        </Grid>

                        <!--  Server URL  -->
                        <StackPanel>
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource SemiColorText2}"
                                Margin="0,0,0,4"
                                Text="服务端地址" />
                            <StackPanel IsVisible="{Binding !IsEditingUrl}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock
                                        FontSize="13"
                                        Text="{Binding ServerUrl}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center" />
                                    <Button
                                        Command="{Binding StartEditUrlCommand}"
                                        Content="编辑"
                                        Grid.Column="1"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        Padding="10,0" />
                                </Grid>
                            </StackPanel>
                            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding IsEditingUrl}">
                                <TextBox FontSize="13" Text="{Binding EditUrl}" />
                                <Button
                                    Classes="Primary"
                                    Command="{Binding SaveUrlCommand}"
                                    Content="保存"
                                    Grid.Column="1"
                                    Height="28"
                                    Margin="8,0,0,0"
                                    Padding="10,0" />
                            </Grid>
                        </StackPanel>

                        <!--  Project Name (read-only)  -->
                        <StackPanel>
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource SemiColorText2}"
                                Margin="0,0,0,4"
                                Text="项目名称（服务端）" />
                            <TextBlock
                                FontSize="13"
                                FontWeight="Medium"
                                Foreground="{DynamicResource SemiColorText0}"
                                Text="{Binding ProjectName}" />
                        </StackPanel>

                        <!--  Ignore Folders  -->
                        <StackPanel>
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource SemiColorText2}"
                                Margin="0,0,0,4"
                                Text="忽略文件夹" />
                            <ItemsControl ItemsSource="{Binding IgnoreFolders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                            <TextBlock
                                                FontSize="12"
                                                Text="{Binding}"
                                                VerticalAlignment="Center" />
                                            <Button
                                                Command="{Binding #Root.((vm:EditProjectDialogViewModel)DataContext).RemoveFolderCommand}"
                                                CommandParameter="{Binding}"
                                                Content="✕"
                                                FontSize="10"
                                                Grid.Column="1"
                                                Height="24"
                                                Padding="0"
                                                Width="24" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                <TextBox
                                    FontSize="12"
                                    Text="{Binding NewFolderItem}"
                                    Watermark="添加文件夹..." />
                                <Button
                                    Command="{Binding #Root.((vm:EditProjectDialogViewModel)DataContext).AddFolderCommand}"
                                    CommandParameter="{Binding #Root.((vm:EditProjectDialogViewModel)DataContext).NewFolderItem}"
                                    Content="添加"
                                    Grid.Column="1"
                                    Height="28"
                                    Margin="6,0,0,0"
                                    Padding="8,0" />
                            </Grid>
                        </StackPanel>

                        <!--  Ignore Files  -->
                        <StackPanel>
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource SemiColorText2}"
                                Margin="0,0,0,4"
                                Text="忽略文件" />
                            <ItemsControl ItemsSource="{Binding IgnoreFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                            <TextBlock
                                                FontSize="12"
                                                Text="{Binding}"
                                                VerticalAlignment="Center" />
                                            <Button
                                                Command="{Binding #Root.((vm:EditProjectDialogViewModel)DataContext).RemoveFileCommand}"
                                                CommandParameter="{Binding}"
                                                Content="✕"
                                                FontSize="10"
                                                Grid.Column="1"
                                                Height="24"
                                                Padding="0"
                                                Width="24" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                <TextBox
                                    FontSize="12"
                                    Text="{Binding NewFileItem}"
                                    Watermark="添加文件规则..." />
                                <Button
                                    Command="{Binding #Root.((vm:EditProjectDialogViewModel)DataContext).AddFileCommand}"
                                    CommandParameter="{Binding #Root.((vm:EditProjectDialogViewModel)DataContext).NewFileItem}"
                                    Content="添加"
                                    Grid.Column="1"
                                    Height="28"
                                    Margin="6,0,0,0"
                                    Padding="8,0" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!--  Buttons  -->
        <Grid
            ColumnDefinitions="*,Auto,Auto,Auto"
            Grid.Row="1"
            Margin="0,16,0,0">
            <TextBlock
                FontSize="11"
                Foreground="{DynamicResource SemiColorText2}"
                Grid.Column="0"
                Text="{Binding StatusMessage}"
                VerticalAlignment="Center" />
            <Button
                Click="CancelBtn_Click"
                Content="取消"
                Grid.Column="1"
                Height="32"
                Margin="0,0,8,0"
                Padding="16,0" />
            <Button
                Classes="Primary"
                Command="{Binding SaveCommand}"
                Content="保存"
                Grid.Column="2"
                Height="32"
                Padding="16,0" />
        </Grid>
    </Grid>
</Window>
