<Window x:Class="AlyPublish.Views.Dialogs.AddProjectDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AlyPublish.ViewModels"
        xmlns:cli="using:AlyPublish.Models.Cli"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:DataType="vm:AddProjectDialogViewModel"
        Title="初始化项目"
        Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SemiColorBg0}"
        CanResize="False">
    <Grid RowDefinitions="*,Auto" Margin="24,20">
        <ScrollViewer>
            <StackPanel Spacing="16">
                <!-- Server URL + 获取项目 -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="Server"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="服务端地址"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding ServerUrl}" Watermark="http://localhost:2000" FontSize="13"/>
                        <Button Grid.Column="1" Command="{Binding FetchProjectsCommand}"
                                Content="获取项目"
                                Margin="8,0,0,0" Height="32" Padding="12,0"
                                Classes="Primary"/>
                    </Grid>
                </StackPanel>

                <!-- 服务端项目列表 -->
                <StackPanel IsVisible="{Binding ShowProjectList}">
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="FormatListBulleted"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="选择服务端项目"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </Grid>
                    <Border BorderBrush="{DynamicResource SemiColorBorder}"
                            BorderThickness="1" CornerRadius="6" MaxHeight="150">
                        <ListBox ItemsSource="{Binding ServerProjects}"
                                 SelectedItem="{Binding SelectedServerProject}"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="cli:ProjectInfo">
                                    <Border Padding="10,6" Margin="0,1" CornerRadius="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource SemiColorText0}"/>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource SemiColorText2}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,2,0,0">
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText3}">
                                                    <Run Text="ID: "/>
                                                    <Run Text="{Binding Id}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource SemiColorText3}">
                                                    <Run Text="版本: "/>
                                                    <Run Text="{Binding Version}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>

                <!-- 创建服务端项目（始终可见） -->
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource SemiColorText2}"
                               IsVisible="{Binding ShowCreateButton}"/>
                    <Button Command="{Binding CreateOnServerCommand}"
                            Content="在服务端新建项目"
                            Height="32" Padding="12,0"
                            Classes="Tertiary"/>
                </StackPanel>

                <!-- Display Name -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="FileDocumentOutline"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="显示名称"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </Grid>
                    <TextBox Text="{Binding DisplayName}"
                             Watermark="例如 MyApp（本地别名，可自定义）" FontSize="13"/>
                </StackPanel>

                <!-- Local Path -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="FolderOutline"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="本地路径（不能包含 .updator/）"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding ProjectPath}"
                                 Watermark="C:\Projects\MyApp\build" FontSize="13"/>
                        <Button Grid.Column="1" Command="{Binding BrowseCommand}"
                                Content="浏览..."
                                Margin="8,0,0,0" Height="32" Padding="12,0"/>
                    </Grid>
                </StackPanel>

                <!-- 初始化状态 -->
                <StackPanel IsVisible="{Binding ShowInitStatus}" Spacing="6">
                    <TextBlock Text="{Binding InitStatusMessage}" FontSize="12"
                               Foreground="{DynamicResource SemiColorText2}"/>
                </StackPanel>

                <!-- 忽略文件夹 -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="FolderRemoveOutline"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="忽略的文件夹（逗号分隔）"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </Grid>
                    <TextBox Text="{Binding IgnoreFolders}"
                             Watermark="node_modules, .git, dist" FontSize="13"/>
                </StackPanel>

                <!-- 忽略文件 -->
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                        <materialIcons:MaterialIcon Grid.Column="0" Kind="FileRemoveOutline"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource SemiColorText1}"/>
                        <TextBlock Grid.Column="1" Text="忽略的文件（逗号分隔）"
                                   FontWeight="Medium" FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SemiColorText0}"/>
                    </Grid>
                    <TextBox Text="{Binding IgnoreFiles}"
                             Watermark="*.log, *.tmp, .DS_Store" FontSize="13"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,20,0,0">
            <TextBlock Grid.Column="0" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Command="{Binding CancelCommand}" Content="取消"
                    Height="32" Padding="16,0" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Command="{Binding ConfirmCommand}" Content="初始化项目"
                    Classes="Primary" Height="32" Padding="16,0"/>
        </Grid>
    </Grid>
</Window>
