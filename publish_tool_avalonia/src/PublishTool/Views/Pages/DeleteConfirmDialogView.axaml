<UserControl
    x:Class="PublishTool.Views.Pages.DeleteConfirmDialogView"
    x:DataType="pages:DeleteConfirmDialogViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:pages="clr-namespace:PublishTool.ViewModels.Pages"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="24">
        <StackPanel Spacing="20">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border
                        Background="{DynamicResource SemiColorDanger}"
                        CornerRadius="20"
                        Height="40"
                        Width="40">
                        <icons:MaterialIcon Foreground="White" Kind="Alert" />
                    </Border>
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource SemiColorDanger}"
                        Text="确认删除项目"
                        VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock
                    FontSize="13"
                    Foreground="{DynamicResource SemiColorText1}"
                    TextWrapping="Wrap">
                    <Run Text="确定要删除项目「" />
                    <Run Text="{Binding ProjectTitle}" />
                    <Run Text="」吗？此操作不可撤销。" />
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
