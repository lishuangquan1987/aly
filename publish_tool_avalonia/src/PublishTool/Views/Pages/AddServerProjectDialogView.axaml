<UserControl
    x:Class="PublishTool.Views.Pages.AddServerProjectDialogView"
    x:DataType="pages:AddServerProjectDialogViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:pages="clr-namespace:PublishTool.ViewModels.Pages"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="24">
        <StackPanel Spacing="20">
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SemiColorText0}"
                    Text="新建服务端项目" />
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource SemiColorText2}"
                    Text="在服务端创建新的发布项目" />
            </StackPanel>

            <StackPanel Spacing="16">
                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource SemiColorText1}"
                        Text="服务器地址" />
                    <Border
                        Background="{DynamicResource SemiColorBg0}"
                        BorderBrush="{DynamicResource SemiColorBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="1">
                        <Grid ColumnDefinitions="28,*">
                            <icons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText2}"
                                HorizontalAlignment="Center"
                                Kind="Server"
                                VerticalAlignment="Center" />
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="13"
                                Grid.Column="1"
                                PlaceholderText="http://192.168.1.100:8080"
                                Text="{Binding ServerUrl}" />
                        </Grid>
                    </Border>
                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource SemiColorDanger}"
                        IsVisible="{Binding ServerUrlError, Converter={StaticResource StringNotEmptyConverter}}"
                        Text="{Binding ServerUrlError}" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource SemiColorText1}"
                        Text="项目名称" />
                    <Border
                        Background="{DynamicResource SemiColorBg0}"
                        BorderBrush="{DynamicResource SemiColorBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="1">
                        <Grid ColumnDefinitions="28,*">
                            <icons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText2}"
                                HorizontalAlignment="Center"
                                Kind="Tag"
                                VerticalAlignment="Center" />
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="13"
                                Grid.Column="1"
                                PlaceholderText="my-project（英文标识）"
                                Text="{Binding Name}" />
                        </Grid>
                    </Border>
                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource SemiColorDanger}"
                        IsVisible="{Binding NameError, Converter={StaticResource StringNotEmptyConverter}}"
                        Text="{Binding NameError}" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource SemiColorText1}"
                        Text="显示标题" />
                    <Border
                        Background="{DynamicResource SemiColorBg0}"
                        BorderBrush="{DynamicResource SemiColorBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="1">
                        <Grid ColumnDefinitions="28,*">
                            <icons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText2}"
                                HorizontalAlignment="Center"
                                Kind="FormatText"
                                VerticalAlignment="Center" />
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="13"
                                Grid.Column="1"
                                PlaceholderText="我的项目（中文显示名）"
                                Text="{Binding Title}" />
                        </Grid>
                    </Border>
                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource SemiColorDanger}"
                        IsVisible="{Binding TitleError, Converter={StaticResource StringNotEmptyConverter}}"
                        Text="{Binding TitleError}" />
                </StackPanel>

                <CheckBox
                    Content="启用强制更新模式"
                    FontSize="12"
                    IsChecked="{Binding IsForceUpdate}" />

                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource SemiColorDanger}"
                    IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                    Text="{Binding StatusMessage}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
