<UserControl
    x:Class="PublishTool.Views.Pages.ChangeLogsDialogView"
    x:DataType="pages:ChangeLogsDialogViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:m="using:PublishTool.Models"
    xmlns:pages="clr-namespace:PublishTool.ViewModels.Pages"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="24">
        <Grid RowDefinitions="Auto,*">
            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{DynamicResource SemiColorText0}"
                Grid.Row="0"
                Margin="0,0,0,16"
                Text="变更日志" />

            <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="12">
                    <ItemsControl ItemsSource="{Binding ChangeLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:ProjectChangeLogDto">
                                <Border
                                    Background="{DynamicResource SemiColorBg0}"
                                    CornerRadius="6"
                                    Padding="12">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SemiColorText0}"
                                                Grid.Column="0"
                                                Text="{Binding Version, StringFormat='📦 v{0}'}" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource SemiColorText2}"
                                                Grid.Column="1"
                                                Text="{Binding CreatedAt}" />
                                        </Grid>
                                        <Border
                                            Background="{DynamicResource SemiColorBg1}"
                                            CornerRadius="4"
                                            Padding="8">
                                            <ItemsControl ItemsSource="{Binding Logs}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <TextBlock
                                                            FontSize="12"
                                                            Foreground="{DynamicResource SemiColorText1}"
                                                            Margin="0,2"
                                                            Text="{Binding}"
                                                            TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
