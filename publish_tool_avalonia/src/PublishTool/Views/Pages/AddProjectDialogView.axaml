<UserControl
    x:Class="PublishTool.Views.Pages.AddProjectDialogView"
    x:DataType="pages:AddProjectDialogViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:m="using:PublishTool.Models"
    xmlns:pages="clr-namespace:PublishTool.ViewModels.Pages"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:vm="using:PublishTool.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="24">
        <StackPanel Spacing="20">
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SemiColorText0}"
                    Text="添加客户端项目" />
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource SemiColorText2}"
                    Text="连接到服务端并关联本地项目文件夹" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource SemiColorText1}"
                    Text="服务器地址" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Border
                        Background="{DynamicResource SemiColorBg0}"
                        BorderBrush="{DynamicResource SemiColorBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="1">
                        <Grid ColumnDefinitions="28,*">
                            <icons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText2}"
                                HorizontalAlignment="Center"
                                Kind="Server"
                                VerticalAlignment="Center" />
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="13"
                                Grid.Column="1"
                                PlaceholderText="http://192.168.1.100:8080"
                                Text="{Binding ServerUrl}" />
                        </Grid>
                    </Border>
                    <Button
                        Classes="Primary"
                        Command="{Binding FetchProjectsCommand}"
                        FontSize="12"
                        Grid.Column="1">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <icons:MaterialIcon Foreground="White" Kind="Download" />
                            <TextBlock Text="获取项目列表" />
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource SemiColorDanger}"
                    IsVisible="{Binding ServerUrlError, Converter={StaticResource StringNotEmptyConverter}}"
                    Text="{Binding ServerUrlError}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource SemiColorText1}"
                    Text="选择项目" />
                <ListBox
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Height="180"
                    ItemsSource="{Binding AvailableProjects}"
                    SelectedItem="{Binding SelectedProject}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:ProjectDto">
                            <Border Padding="10,6">
                                <StackPanel Spacing="2">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource SemiColorText0}"
                                        Text="{Binding Title}" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{DynamicResource SemiColorText2}"
                                        Text="{Binding Name}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource SemiColorText1}"
                    Text="本地文件夹路径" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Border
                        Background="{DynamicResource SemiColorBg0}"
                        BorderBrush="{DynamicResource SemiColorBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="1">
                        <Grid ColumnDefinitions="28,*">
                            <icons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText2}"
                                HorizontalAlignment="Center"
                                Kind="Folder"
                                VerticalAlignment="Center" />
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="13"
                                Grid.Column="1"
                                PlaceholderText="D:\Projects\MyApp"
                                Text="{Binding LocalPath}" />
                        </Grid>
                    </Border>
                    <Button
                        Command="{Binding SelectFolderCmd}"
                        FontSize="12"
                        Grid.Column="1">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <icons:MaterialIcon Foreground="{DynamicResource SemiColorText1}" Kind="FolderOpen" />
                            <TextBlock Text="浏览..." />
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource SemiColorDanger}"
                    IsVisible="{Binding LocalPathError, Converter={StaticResource StringNotEmptyConverter}}"
                    Text="{Binding LocalPathError}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource SemiColorText1}"
                    Text="可执行文件路径（可选）" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Border
                        Background="{DynamicResource SemiColorBg0}"
                        BorderBrush="{DynamicResource SemiColorBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="1">
                        <Grid ColumnDefinitions="28,*">
                            <icons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText2}"
                                HorizontalAlignment="Center"
                                Kind="Application"
                                VerticalAlignment="Center" />
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="13"
                                Grid.Column="1"
                                PlaceholderText="D:\Projects\MyApp\app.exe"
                                Text="{Binding ExePath}" />
                        </Grid>
                    </Border>
                    <Button
                        Command="{Binding SelectExeCmd}"
                        FontSize="12"
                        Grid.Column="1">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <icons:MaterialIcon Foreground="{DynamicResource SemiColorText1}" Kind="FileSearch" />
                            <TextBlock Text="浏览..." />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
