<Window
    ExtendClientAreaToDecorationsHint="True"
    Height="850"
    MinHeight="650"
    MinWidth="1100"
    Title="发布工具"
    TransparencyLevelHint="AcrylicBlur"
    Width="1400"
    WindowStartupLocation="CenterScreen"
    x:Class="PublishTool.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    x:Name="UC"
    xmlns="https://github.com/avaloniaui"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:views="clr-namespace:PublishTool.Views"
    xmlns:vm="using:PublishTool.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnDefinitions="280,*" RowDefinitions="48,*,32">

        <!--  ===== 顶栏 =====  -->
        <Border
            Background="{DynamicResource SemiColorBg0}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,0,0,1"
            Grid.ColumnSpan="2"
            Grid.Row="0">
            <Grid
                ColumnDefinitions="Auto,*,Auto"
                Margin="16,0"
                VerticalAlignment="Center">
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="10">
                    <Border
                        Background="{DynamicResource SemiColorPrimary}"
                        CornerRadius="8"
                        Height="30"
                        Width="30">
                        <icons:MaterialIcon
                            Foreground="White"
                            Height="18"
                            HorizontalAlignment="Center"
                            Kind="CloudUpload"
                            VerticalAlignment="Center"
                            Width="18" />
                    </Border>
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="发布工具"
                        VerticalAlignment="Center" />
                </StackPanel>

                <Border
                    Background="{DynamicResource SemiColorFill0}"
                    CornerRadius="10"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Padding="10,3"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <icons:MaterialIcon
                            Foreground="{DynamicResource SemiColorPrimary}"
                            Height="14"
                            Kind="FolderMultiple"
                            VerticalAlignment="Center"
                            Width="14" />
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource SemiColorPrimary}"
                            VerticalAlignment="Center">
                            <Run Text="{Binding FilteredProjects.Count}" />
                            <Run Text=" 个项目" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!--  ===== 左侧：项目列表面板 =====  -->
        <Border
            Background="{DynamicResource SemiColorBg1}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,0,1,0"
            Grid.Column="0"
            Grid.Row="1">
            <views:ProjectListPanel />
        </Border>

        <!--  ===== 右侧：主内容区 =====  -->
        <Grid
            Background="{DynamicResource SemiColorBg1}"
            Grid.Column="1"
            Grid.Row="1">
            <Grid RowDefinitions="40,*">

                <!--  Tab 栏  -->
                <Border
                    Background="{DynamicResource SemiColorBg0}"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="0,0,0,1"
                    Grid.Row="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TabControl
                            Grid.Column="0"
                            ItemsSource="{Binding OpenTabs}"
                            Padding="8,0,0,0"
                            SelectedItem="{Binding SelectedTab}"
                            TabStripPlacement="Top">
                            <TabControl.Styles>
                                <Style Selector="TabItem">
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="Margin" Value="0,4,2,0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <Style Selector="TabItem:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource SemiColorFill0}" />
                                </Style>
                                <Style Selector="TabItem:selected">
                                    <Setter Property="Background" Value="{DynamicResource SemiColorBg1}" />
                                    <Setter Property="Foreground" Value="{DynamicResource SemiColorPrimary}" />
                                </Style>
                            </TabControl.Styles>
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="6">
                                        <Border
                                            Background="{DynamicResource SemiColorPrimary}"
                                            CornerRadius="3"
                                            Grid.Column="0"
                                            Height="8"
                                            Opacity="0.8"
                                            VerticalAlignment="Center"
                                            Width="8" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{DynamicResource SemiColorText0}"
                                            Grid.Column="1"
                                            MaxWidth="140"
                                            Text="{Binding Config.Title}"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center" />
                                        <Button
                                            Background="Transparent"
                                            Classes="Tertiary"
                                            Command="{Binding #UC.((vm:MainWindowViewModel)DataContext).CloseTabCommand}"
                                            CommandParameter="{Binding}"
                                            Grid.Column="2"
                                            Height="30"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            Width="30">
                                            <icons:MaterialIcon
                                                Foreground="{DynamicResource SemiColorText2}"
                                                Height="14"
                                                HorizontalAlignment="Center"
                                                Kind="Close"
                                                VerticalAlignment="Center"
                                                Width="14" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>

                        <StackPanel
                            Grid.Column="1"
                            Margin="0,0,12,0"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                            <Button
                                Classes="Tertiary"
                                Command="{Binding CloseAllTabsCommand}"
                                FontSize="11"
                                Padding="6,4"
                                ToolTip.Tip="关闭全部标签">
                                <icons:MaterialIcon
                                    Foreground="{DynamicResource SemiColorText2}"
                                    Height="16"
                                    Kind="CloseCircleOutline"
                                    Width="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  内容区 - 空状态  -->
                <Grid Grid.Row="1">
                    <ContentControl Content="{Binding SelectedTab}" />

                    <Panel IsVisible="True" x:Name="EmptyContentOverlay">
                        <StackPanel
                            HorizontalAlignment="Center"
                            Opacity="0.4"
                            Spacing="16"
                            VerticalAlignment="Center">
                            <icons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText2}"
                                Height="64"
                                HorizontalAlignment="Center"
                                Kind="ArrowLeftBold"
                                Width="64" />
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource SemiColorText2}"
                                HorizontalAlignment="Center"
                                Text="选择左侧项目开始" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource SemiColorText2}"
                                HorizontalAlignment="Center"
                                Text="创建或添加项目后，点击即可打开" />
                        </StackPanel>
                    </Panel>
                </Grid>

            </Grid>
        </Grid>

        <!--  ===== 底部状态栏 =====  -->
        <Border
            Background="{DynamicResource SemiColorBg0}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,1,0,0"
            Grid.ColumnSpan="2"
            Grid.Row="2">
            <Grid
                ColumnDefinitions="Auto,*,Auto"
                Margin="12,0"
                VerticalAlignment="Center">
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="6">
                    <Border
                        Background="{DynamicResource SemiColorSuccess}"
                        CornerRadius="4"
                        Height="8"
                        Width="8" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource SemiColorText2}"
                        Text="就绪"
                        VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource SemiColorPrimary}"
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    Text="{Binding SelectedTab.StatusMessage, TargetNullValue='就绪'}"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <icons:MaterialIcon
                            Foreground="{DynamicResource SemiColorText2}"
                            Height="14"
                            Kind="Server"
                            VerticalAlignment="Center"
                            Width="14" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{DynamicResource SemiColorText2}"
                            VerticalAlignment="Center">
                            <Run Text="{Binding SelectedTab.Config.ServerUrl, TargetNullValue='未连接', FallbackValue='未连接'}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
