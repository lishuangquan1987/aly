<semi:Window xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:semi="https://irihi.tech/semi"
              xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
              xmlns:controls="using:PublishTool.Views.Controls"
              xmlns:vm="using:PublishTool.ViewModels"
              x:Class="PublishTool.Views.MainWindow"
              x:DataType="vm:MainWindowViewModel"
              Title="发布工具"
              Width="1400" Height="850"
              MinWidth="1100" MinHeight="650"
              WindowStartupLocation="CenterScreen"
              ExtendClientAreaToDecorationsHint="True"
              TransparencyLevelHint="AcrylicBlur">

  <Grid RowDefinitions="48,*,32" ColumnDefinitions="280,*">

    <!-- ===== 顶栏 ===== -->
    <Border Grid.Row="0" Grid.ColumnSpan="2"
            Background="{DynamicResource SemiColorBg0}"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SemiColorBorder}">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,0" VerticalAlignment="Center">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
          <Border Background="{DynamicResource SemiColorPrimary}"
                  CornerRadius="8" Width="30" Height="30">
            <icons:MaterialIcon Kind="CloudUpload" Foreground="White"
                                Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="发布工具"
                     FontSize="15" FontWeight="SemiBold"
                     Foreground="{DynamicResource SemiColorText0}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Column="2"
                Background="{DynamicResource SemiColorFill0}"
                CornerRadius="10" Padding="10,3"
                HorizontalAlignment="Right" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <icons:MaterialIcon Kind="FolderMultiple"
                                Foreground="{DynamicResource SemiColorPrimary}"
                                Width="14" Height="14" VerticalAlignment="Center"/>
            <TextBlock FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource SemiColorPrimary}"
                       VerticalAlignment="Center">
              <Run Text="{Binding FilteredProjects.Count}"/>
              <Run Text=" 个项目"/>
            </TextBlock>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <!-- ===== 左侧：项目列表面板 ===== -->
    <Border Grid.Row="1" Grid.Column="0"
            Background="{DynamicResource SemiColorBg1}"
            BorderThickness="0,0,1,0"
            BorderBrush="{DynamicResource SemiColorBorder}">
      <controls:ProjectListPanel />
    </Border>

    <!-- ===== 右侧：主内容区 ===== -->
    <Grid Grid.Row="1" Grid.Column="1"
          Background="{DynamicResource SemiColorBg1}">
      <Grid RowDefinitions="40,*">

        <!-- Tab 栏 -->
        <Border Grid.Row="0"
                Background="{DynamicResource SemiColorBg0}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SemiColorBorder}">
          <Grid ColumnDefinitions="*,Auto">
            <TabControl Grid.Column="0"
                        ItemsSource="{Binding OpenTabs}"
                        SelectedItem="{Binding SelectedTab}"
                        TabStripPlacement="Top"
                        Padding="8,0,0,0">
              <TabControl.Styles>
                <Style Selector="TabItem">
                  <Setter Property="FontSize" Value="12"/>
                  <Setter Property="Padding" Value="8,4"/>
                  <Setter Property="Margin" Value="0,4,2,0"/>
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="TabItem:pointerover">
                  <Setter Property="Background" Value="{DynamicResource SemiColorFill0}"/>
                </Style>
                <Style Selector="TabItem:selected">
                  <Setter Property="Background" Value="{DynamicResource SemiColorBg1}"/>
                  <Setter Property="Foreground" Value="{DynamicResource SemiColorPrimary}"/>
                </Style>
              </TabControl.Styles>
              <TabControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6">
                    <Border Grid.Column="0"
                            CornerRadius="3"
                            Width="8" Height="8"
                            VerticalAlignment="Center"
                            Background="{DynamicResource SemiColorPrimary}"
                            Opacity="0.8"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Config.Title}"
                               FontSize="12"
                               Foreground="{DynamicResource SemiColorText0}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="140"/>
                    <Button Grid.Column="2"
                            Width="20" Height="20"
                            Padding="0"
                            Classes="Tertiary"
                            VerticalAlignment="Center"
                            Command="{Binding $parent[Window].DataContext.CloseTabCommand}"
                            CommandParameter="{Binding}">
                      <icons:MaterialIcon Kind="Close" Width="14" Height="14"
                                          Foreground="{DynamicResource SemiColorText2}"/>
                    </Button>
                  </Grid>
                </DataTemplate>
              </TabControl.ItemTemplate>
            </TabControl>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,12,0" Spacing="4">
              <Button Classes="Tertiary" Padding="6,4" FontSize="11"
                      Command="{Binding CloseAllTabsCommand}"
                      ToolTip.Tip="关闭全部标签">
                <icons:MaterialIcon Kind="CloseCircleOutline"
                                    Foreground="{DynamicResource SemiColorText2}"
                                    Width="16" Height="16"/>
              </Button>
            </StackPanel>
          </Grid>
        </Border>

        <!-- 内容区 - 空状态 -->
        <Grid Grid.Row="1">
          <ContentControl Content="{Binding SelectedTab}" />

          <Panel x:Name="EmptyContentOverlay" IsVisible="True">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="16" Opacity="0.4">
              <icons:MaterialIcon Kind="ArrowLeftBold" Width="64" Height="64"
                                  Foreground="{DynamicResource SemiColorText2}"
                                  HorizontalAlignment="Center"/>
              <TextBlock Text="选择左侧项目开始" FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource SemiColorText2}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="创建或添加项目后，点击即可打开" FontSize="12"
                         Foreground="{DynamicResource SemiColorText2}"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Panel>
        </Grid>

      </Grid>
    </Grid>

    <!-- ===== 底部状态栏 ===== -->
    <Border Grid.Row="2" Grid.ColumnSpan="2"
            Background="{DynamicResource SemiColorBg0}"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SemiColorBorder}">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0" VerticalAlignment="Center">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
          <Border Width="8" Height="8" CornerRadius="4"
                  Background="{DynamicResource SemiColorSuccess}"/>
          <TextBlock Text="就绪" FontSize="11"
                     Foreground="{DynamicResource SemiColorText2}"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Column="1"
                   Text="{Binding SelectedTab.StatusMessage, TargetNullValue='就绪'}"
                   FontSize="11"
                   Foreground="{DynamicResource SemiColorPrimary}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Margin="16,0,0,0"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <icons:MaterialIcon Kind="Server" Foreground="{DynamicResource SemiColorText2}"
                                Width="14" Height="14" VerticalAlignment="Center"/>
            <TextBlock FontSize="11" Foreground="{DynamicResource SemiColorText2}" VerticalAlignment="Center">
              <Run Text="{Binding SelectedTab.Config.ServerUrl, TargetNullValue='未连接', FallbackValue='未连接'}"/>
            </TextBlock>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

  </Grid>
</semi:Window>
