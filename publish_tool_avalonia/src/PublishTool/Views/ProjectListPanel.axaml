<UserControl
    x:Class="PublishTool.Views.ProjectListPanel"
    x:DataType="vm:MainWindowViewModel"
    x:Name="UC"
    xmlns="https://github.com/avaloniaui"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:ml="using:PublishTool.Models.Local"
    xmlns:vm="using:PublishTool.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!--  Row 0: 标题区  -->
        <Border
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,0,0,1"
            Grid.Row="0"
            Padding="16,14,16,10">
            <Grid ColumnDefinitions="Auto,*">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <Border
                        Background="{DynamicResource SemiColorPrimary}"
                        CornerRadius="6"
                        Height="26"
                        VerticalAlignment="Center"
                        Width="26">
                        <icons:MaterialIcon
                            Foreground="White"
                            Height="16"
                            HorizontalAlignment="Center"
                            Kind="FolderStar"
                            VerticalAlignment="Center"
                            Width="16" />
                    </Border>
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource SemiColorText0}"
                        Text="项目管理"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Row 1: 操作区  -->
        <Border
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,0,0,1"
            Grid.Row="1"
            Padding="16,10,16,12">
            <StackPanel Spacing="8">
                <Border
                    Background="{DynamicResource SemiColorBg0}"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="1">
                    <Grid ColumnDefinitions="28,*">
                        <icons:MaterialIcon
                            Foreground="{DynamicResource SemiColorText2}"
                            Grid.Column="0"
                            Height="16"
                            HorizontalAlignment="Center"
                            Kind="Magnify"
                            VerticalAlignment="Center"
                            Width="16" />
                        <TextBox
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="13"
                            Grid.Column="1"
                            PlaceholderText="搜索项目..."
                            Text="{Binding SearchText, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button
                        Classes="Primary"
                        Command="{Binding AddServerProjectCommand}"
                        FontSize="12"
                        Grid.Column="0"
                        HorizontalContentAlignment="Center"
                        Theme="{DynamicResource SolidButton}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:MaterialIcon
                                Height="16"
                                Kind="ServerPlus"
                                Width="16" />
                            <TextBlock Text="服务端项目" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button
                        Classes="Tertiary"
                        Command="{Binding AddClientProjectCommand}"
                        FontSize="12"
                        Grid.Column="1"
                        HorizontalContentAlignment="Center"
                        Theme="{DynamicResource SolidButton}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:MaterialIcon
                                Foreground="{DynamicResource SemiColorText1}"
                                Height="16"
                                Kind="FolderPlus"
                                Width="16" />
                            <TextBlock Text="客户端项目" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!--  Row 2: 项目列表  -->
        <ListBox
            BorderThickness="0"
            Grid.Row="2"
            ItemsSource="{Binding FilteredProjects}"
            Padding="6,8"
            SelectedItem="{Binding SelectedProject}"
            x:Name="ProjectListBox">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,2" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="CornerRadius" Value="8" />
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource SemiColorFill0}" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource SemiColorPrimary}" />
                    <Setter Property="CornerRadius" Value="8" />
                    <Setter Property="Foreground" Value="White" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="ml:ProjectConfig">
                    <Border
                        Background="Transparent"
                        CornerRadius="8"
                        MinHeight="64"
                        Padding="12,10">
                        <Grid RowDefinitions="Auto,Auto,Auto">
                            <!--  标题行  -->
                            <Grid
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="8"
                                Grid.Row="0">
                                <Border
                                    Background="{DynamicResource SemiColorPrimary}"
                                    CornerRadius="6"
                                    Grid.Column="0"
                                    Height="32"
                                    VerticalAlignment="Center"
                                    Width="32">
                                    <icons:MaterialIcon
                                        Foreground="White"
                                        Height="18"
                                        HorizontalAlignment="Center"
                                        Kind="PackageVariantClosed"
                                        VerticalAlignment="Center"
                                        Width="18" />
                                </Border>
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource SemiColorText0}"
                                    Grid.Column="1"
                                    Text="{Binding Title}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />
                                <Border
                                    Background="{DynamicResource SemiColorFill0}"
                                    CornerRadius="4"
                                    Grid.Column="2"
                                    Padding="6,2"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="{DynamicResource SemiColorText2}"
                                        Text="{Binding ServerId}"
                                        VerticalAlignment="Center" />
                                </Border>
                            </Grid>

                            <StackPanel
                                Grid.Row="1"
                                Margin="2"
                                Orientation="Horizontal"
                                Spacing="3">
                                <icons:MaterialIcon
                                    Foreground="{DynamicResource SemiColorText2}"
                                    Height="11"
                                    Kind="LinkVariant"
                                    VerticalAlignment="Center"
                                    Width="11" />
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{DynamicResource SemiColorText2}"
                                    Text="{Binding ServerUrl, TargetNullValue='未配置'}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="2"
                                Margin="2"
                                Orientation="Horizontal"
                                Spacing="3">
                                <icons:MaterialIcon
                                    Foreground="{DynamicResource SemiColorText2}"
                                    Height="11"
                                    Kind="FolderOutline"
                                    VerticalAlignment="Center"
                                    Width="11" />
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{DynamicResource SemiColorText2}"
                                    Text="{Binding LocalPath, TargetNullValue='未设置'}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <!--  右键菜单  -->
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem
                                    Command="{Binding #UC.((vm:MainWindowViewModel)DataContext).MoveUpProjectCommand}"
                                    CommandParameter="{Binding}"
                                    Header="上移排序">
                                    <MenuItem.Icon>
                                        <icons:MaterialIcon
                                            Height="16"
                                            Kind="ChevronUp"
                                            Width="16" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem
                                    Command="{Binding #UC.((vm:MainWindowViewModel)DataContext).MoveDownProjectCommand}"
                                    CommandParameter="{Binding}"
                                    Header="下移排序">
                                    <MenuItem.Icon>
                                        <icons:MaterialIcon
                                            Height="16"
                                            Kind="ChevronDown"
                                            Width="16" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem
                                    Command="{Binding #UC.((vm:MainWindowViewModel)DataContext).RemoveProjectCommand}"
                                    CommandParameter="{Binding}"
                                    Header="删除项目">
                                    <MenuItem.Icon>
                                        <icons:MaterialIcon
                                            Height="16"
                                            Kind="DeleteOutline"
                                            Width="16" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Border.ContextMenu>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!--  空状态覆盖层  -->
        <Panel IsVisible="False" x:Name="EmptyOverlay">
            <StackPanel
                HorizontalAlignment="Center"
                Opacity="0.4"
                Spacing="12"
                VerticalAlignment="Center">
                <icons:MaterialIcon
                    Foreground="{DynamicResource SemiColorText2}"
                    Height="48"
                    HorizontalAlignment="Center"
                    Kind="FolderOff"
                    Width="48" />
                <StackPanel HorizontalAlignment="Center" Spacing="4">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource SemiColorText2}"
                        HorizontalAlignment="Center"
                        Text="暂无项目" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource SemiColorText2}"
                        HorizontalAlignment="Center"
                        Text="点击上方按钮添加项目" />
                </StackPanel>
            </StackPanel>
        </Panel>

        <!--  底部：快速操作提示  -->
        <Border
            Background="{DynamicResource SemiColorBg0}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="0,1,0,0"
            Grid.Row="3"
            Padding="16,8">
            <TextBlock
                FontSize="10"
                Foreground="{DynamicResource SemiColorText2}"
                TextTrimming="CharacterEllipsis"
                VerticalAlignment="Center">
                <Run Text="右键项目可排序或删除" />
            </TextBlock>
        </Border>

    </Grid>
</UserControl>
