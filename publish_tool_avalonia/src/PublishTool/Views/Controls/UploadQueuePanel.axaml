<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PublishTool.ViewModels"
             xmlns:ml="using:PublishTool.Models.Local"
             x:Class="PublishTool.Views.Controls.UploadQueuePanel"
             x:DataType="vm:ProjectPageViewModel"
             Padding="8">
  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <!-- 版本号输入 -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,4">
      <TextBlock Text="版本号" FontSize="11" Foreground="#888888"/>
      <TextBox Text="{Binding NewVersion}" 
               PlaceholderText="输入版本号..."
               Width="120" Height="24"
               Background="#1a1a1a" Foreground="White"
               BorderBrush="#3d3d3d" BorderThickness="1"
               CornerRadius="3" FontSize="11"/>
    </StackPanel>

    <!-- 更新日志 -->
    <StackPanel Grid.Row="1" Margin="0,4">
      <TextBlock Text="更新日志" FontSize="11" Foreground="#888888" Margin="0,0,0,4"/>
      <TextBox Text="{Binding ChangeLogText}" 
               PlaceholderText="输入更新日志..."
               Height="80"
               Background="#1a1a1a" Foreground="White"
               BorderBrush="#3d3d3d" BorderThickness="1"
               CornerRadius="3" FontSize="11"
               TextWrapping="Wrap" AcceptsReturn="True"/>
    </StackPanel>

    <!-- 待上传文件列表 -->
    <ScrollViewer Grid.Row="2" Background="#1a1a1a" CornerRadius="3" BorderThickness="0">
      <StackPanel Orientation="Vertical">
        <TextBlock Text="待上传文件" FontSize="11" Foreground="#888888" Margin="4,4"/>
        <ListBox ItemsSource="{Binding UploadFiles}" Margin="0,4">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="ml:UploadFileItem">
              <StackPanel Orientation="Horizontal" Height="24">
                <CheckBox IsChecked="{Binding IsChecked}" Width="24" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding FileName}" FontSize="10" Foreground="White" Width="200"/>
                <TextBlock Text="{Binding LastModified, StringFormat='{}{0:MM-dd HH:mm}'}" 
                           FontSize="10" Foreground="#888888" Width="80"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.Styles>
            <Style Selector="ListBox">
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
            </Style>
          </ListBox.Styles>
        </ListBox>
        <TextBlock Text="{Binding UploadFiles.Count, StringFormat='共 {0} 个文件'}" 
                   FontSize="10" Foreground="#666666" Margin="4,4"/>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>