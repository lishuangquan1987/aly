<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:vm="using:PublishTool.ViewModels"
             xmlns:ml="using:PublishTool.Models.Local"
             xmlns:conv="using:PublishTool.Converters"
             x:Class="PublishTool.Views.Controls.UploadQueuePanel"
             x:DataType="vm:ProjectPageViewModel"
             Padding="12">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="8">
    <!-- 标题 -->
    <TextBlock Grid.Row="0" Text="待推送版本"
               FontSize="12" FontWeight="SemiBold"
               Foreground="{DynamicResource TextBase}"/>

    <!-- 版本号输入 -->
    <Border Grid.Row="1" BorderThickness="1"
            BorderBrush="{DynamicResource BorderColor}"
            CornerRadius="4" Padding="8">
      <StackPanel Spacing="6">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
          <TextBlock Grid.Column="0" Text="版本号" FontSize="11"
                     Foreground="{DynamicResource TextTertiary}"
                     VerticalAlignment="Center"/>
          <Grid Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="4">
            <atom:TextBox Grid.Column="0" Text="{Binding NewVersion}"
                          PlaceholderText="输入版本号..." FontSize="11"/>
            <atom:Button Grid.Column="1" Content="自动" ButtonType="Text"
                         Command="{Binding AutoGenerateVersionCommand}"
                         FontSize="11"/>
          </Grid>
        </Grid>
        <StackPanel Spacing="4">
          <TextBlock Text="更新日志" FontSize="11"
                     Foreground="{DynamicResource TextTertiary}"/>
          <atom:TextBox Text="{Binding ChangeLogText}"
                        PlaceholderText="输入更新日志..."
                        Height="60"
                        TextWrapping="Wrap" AcceptsReturn="True"
                        FontSize="11"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- 文件数量统计 -->
    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
        <TextBlock Text="待上传" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
        <TextBlock Text="{Binding UploadFiles.Count}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
        <TextBlock Text="|" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
        <TextBlock Text="已完成" FontSize="11" Foreground="{DynamicResource SuccessColor}"/>
        <TextBlock Text="{Binding UploadCompletedCount}" FontSize="11" Foreground="{DynamicResource SuccessColor}"/>
      </StackPanel>
      <atom:Button Grid.Column="1" Content="清空" ButtonType="Text"
                   Command="{Binding ClearQueueCommand}"
                   FontSize="10"/>
    </Grid>

<!-- 待上传文件列表 -->
    <atom:ScrollViewer Grid.Row="3"
                        Background="{DynamicResource BgLayout}"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource BorderColor}">
      <atom:ListBox ItemsSource="{Binding UploadFiles}"
                    BorderThickness="0">
        <atom:ListBox.ItemTemplate>
          <DataTemplate x:DataType="ml:UploadFileItem">
            <Border Height="32" Padding="4,0">
              <Grid ColumnDefinitions="24,*,60,24">
                <atom:CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}"
                               VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                  <TextBlock Text="{Binding FileName}" FontSize="11"
                             Foreground="{DynamicResource TextBase}"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Text="{Binding RelativePath}" FontSize="9"
                             Foreground="{DynamicResource TextTertiary}"
                             TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Border Grid.Column="2" CornerRadius="3" Padding="4,1"
                        VerticalAlignment="Center" HorizontalAlignment="Left"
                        Background="{Binding Status, Converter={StaticResource UploadStatusToColorConverter}}">
                  <TextBlock Text="{Binding Status, Converter={StaticResource UploadStatusToTextConverter}}"
                             FontSize="9" Foreground="White"/>
                </Border>
                <atom:Button Grid.Column="3" Width="20" Height="20" ButtonType="Text"
                             Command="{Binding $parent[atom:ListBox].((vm:ProjectPageViewModel)DataContext).RetryUploadCommand}"
                             CommandParameter="{Binding}"
                             IsVisible="{Binding Status, Converter={StaticResource UploadStatusToFailedConverter}}"
                             ToolTip.Tip="重试">
                  <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                        Width="12" Height="12" Fill="{DynamicResource PrimaryColor}"/>
                </atom:Button>
              </Grid>
            </Border>
          </DataTemplate>
        </atom:ListBox.ItemTemplate>
      </atom:ListBox>
    </atom:ScrollViewer>

    <!-- 操作按钮 -->
    <atom:Button Grid.Row="4" Content="推送更新" ButtonType="Primary"
                 Command="{Binding PushAllCommand}"
                 IsEnabled="{Binding !IsUploading}"
                 HorizontalAlignment="Stretch"/>
  </Grid>
</UserControl>