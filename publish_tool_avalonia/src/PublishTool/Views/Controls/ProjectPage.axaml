<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:vm="using:PublishTool.ViewModels"
             xmlns:ml="using:PublishTool.Models.Local"
             xmlns:controls="using:PublishTool.Views.Controls"
             x:Class="PublishTool.Views.Controls.ProjectPage"
             x:DataType="vm:ProjectPageViewModel"
             Background="{DynamicResource BgContainer}">
  <Grid RowDefinitions="40,*,36">
    <!-- 顶部工具栏 -->
    <Border Grid.Row="0"
            Background="{DynamicResource BgLayout}"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource BorderColor}">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0">
        <!-- 左侧按钮组 -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <atom:Button Content="刷新" ButtonType="Default"
                       Command="{Binding RefreshStatusCommand}" FontSize="12"/>
          <atom:Button Content="启动" ButtonType="Primary"
                       Command="{Binding StartDefaultCommand}" FontSize="12"/>
          <Border Width="1" Background="{DynamicResource BorderColor}" Margin="4,4"/>
          <atom:Button Content="设置" ButtonType="Text"
                       Command="{Binding OpenSettingsCommand}" FontSize="12"/>
          <atom:Button Content="目录" ButtonType="Text"
                       Command="{Binding OpenExplorerCommand}" FontSize="12"/>
        </StackPanel>

        <!-- 右侧状态 -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <TextBlock Text="{Binding ServerVersion, StringFormat='v{0}', TargetNullValue='v-'}"
                     FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
          <TextBlock Text="{Binding StatusMessage, TargetNullValue='就绪'}"
                     FontSize="11" Foreground="{DynamicResource PrimaryColor}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 主内容区：左右分栏 -->
    <Grid Grid.Row="1" ColumnDefinitions="*,280">
      <!-- 左侧：文件列表 -->
      <Border Grid.Column="0" Margin="8" CornerRadius="6"
              BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
        <Grid RowDefinitions="32,*">
          <!-- 列表头部 -->
          <Border Grid.Row="0" Padding="12,0" BorderThickness="0,0,0,1"
                  BorderBrush="{DynamicResource BorderColor}">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
              <TextBlock Grid.Column="0" Text="文件" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextBase}" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1" Text="{Binding LocalFiles.Count, StringFormat=' ({0})'}"
                         FontSize="11" Foreground="{DynamicResource TextTertiary}"
                         VerticalAlignment="Center" Margin="4,0,0,0"/>
              <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                <atom:Button Content="扫描" ButtonType="Text" FontSize="11"
                             Command="{Binding ScanLocalFilesCommand}"/>
                <atom:Button Content="拉取" ButtonType="Text" FontSize="11"
                             Command="{Binding PullUpdateCommand}"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- 文件列表 -->
          <atom:ScrollViewer Grid.Row="1" Margin="8">
            <atom:ListBox ItemsSource="{Binding LocalFiles}" BorderThickness="0">
              <atom:ListBox.ItemTemplate>
                <DataTemplate x:DataType="ml:LocalFileItem">
                  <Border Padding="8,6" Margin="0,1">
                    <Grid ColumnDefinitions="24,*,60,80">
                      <atom:CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}"
                                     VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding FileName}" FontSize="12"
                                 Foreground="{DynamicResource TextBase}"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="2" Text="{Binding FileSize, Converter={StaticResource BytesToSizeConverter}}"
                                 FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="3" Text="{Binding LastModified, StringFormat='{}{0:MM-dd HH:mm}'}"
                                 FontSize="10" Foreground="{DynamicResource TextTertiary}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </atom:ListBox.ItemTemplate>
            </atom:ListBox>
          </atom:ScrollViewer>
        </Grid>
      </Border>

      <!-- 右侧：上传队列 -->
      <Border Grid.Column="1" Margin="0,8,8,8" CornerRadius="6"
              BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
        <Grid RowDefinitions="32,Auto,*,Auto">
          <!-- 队列标题 -->
          <Border Grid.Row="0" Padding="12,0" BorderThickness="0,0,0,1"
                  BorderBrush="{DynamicResource BorderColor}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="上传队列" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextBase}" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1" Text="{Binding UploadFiles.Count, StringFormat='({0})'}"
                         FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
            </Grid>
          </Border>

          <!-- 版本输入 -->
          <Border Grid.Row="1" Padding="12,8" BorderThickness="0,0,0,1"
                  BorderBrush="{DynamicResource BorderColor}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <atom:TextBox Grid.Column="0" Text="{Binding NewVersion}"
                              PlaceholderText="版本号" FontSize="12"/>
                <atom:Button Grid.Column="1" Content="自动" ButtonType="Text" FontSize="11"
                             Command="{Binding AutoGenerateVersionCommand}" Margin="4,0,0,0"/>
              </Grid>
              <atom:TextBox Grid.Row="1" Text="{Binding ChangeLogText}"
                            PlaceholderText="更新说明" FontSize="11"
                            AcceptsReturn="True" Height="50" TextWrapping="Wrap"/>
            </Grid>
          </Border>

          <!-- 文件列表 -->
          <atom:ScrollViewer Grid.Row="2" Margin="8">
            <atom:ListBox ItemsSource="{Binding UploadFiles}" BorderThickness="0">
              <atom:ListBox.ItemTemplate>
                <DataTemplate x:DataType="ml:UploadFileItem">
                  <Border Padding="4,4" Margin="0,1">
                    <Grid ColumnDefinitions="*,40">
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding FileName}" FontSize="11"
                                   Foreground="{DynamicResource TextBase}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding RelativePath}" FontSize="9"
                                   Foreground="{DynamicResource TextTertiary}"
                                   TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Status, Converter={StaticResource UploadStatusToTextConverter}}"
                                 FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Foreground="{Binding Status, Converter={StaticResource UploadStatusToColorConverter}}"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </atom:ListBox.ItemTemplate>
            </atom:ListBox>
          </atom:ScrollViewer>

          <!-- 底部按钮 -->
          <Border Grid.Row="3" Padding="8" BorderThickness="0,1,0,0"
                  BorderBrush="{DynamicResource BorderColor}">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <atom:CheckBox Content="附加版本" IsChecked="{Binding AppendToLatestVersion}" FontSize="10"/>
              </StackPanel>
              <atom:Button Grid.Column="1" Content="清空" ButtonType="Default" FontSize="11"
                           Command="{Binding ClearQueueCommand}" Margin="0,0,4,0"/>
              <atom:Button Grid.Column="2" Content="推送" ButtonType="Primary" FontSize="11"
                           Command="{Binding PushAllCommand}"/>
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- 底部状态栏 -->
    <Border Grid.Row="2"
            Background="{DynamicResource BgLayout}"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource BorderColor}">
      <Grid ColumnDefinitions="*,Auto,Auto" Margin="12,0">
        <TextBlock Grid.Column="0" Text="{Binding StatusMessage, TargetNullValue='就绪'}"
                   FontSize="11" Foreground="{DynamicResource TextSecondary}"
                   VerticalAlignment="Center"/>
        <atom:ProgressBar Grid.Column="1" Width="100" Height="6" Margin="8,0"
                          Value="{Binding UploadProgress}" Minimum="0" Maximum="100"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsUploading}"/>
        <TextBlock Grid.Column="2" Text="{Binding UploadProgress, StringFormat='{}{0}%'}"
                   FontSize="10" Foreground="{DynamicResource TextTertiary}"
                   VerticalAlignment="Center" IsVisible="{Binding IsUploading}"/>
      </Grid>
    </Border>
  </Grid>
</UserControl>