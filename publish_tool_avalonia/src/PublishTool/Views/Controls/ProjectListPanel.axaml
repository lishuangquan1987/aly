<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:ml="using:PublishTool.Models.Local"
             xmlns:vm="using:PublishTool.ViewModels"
             x:Class="PublishTool.Views.Controls.ProjectListPanel"
             x:DataType="vm:MainWindowViewModel">

  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <Border Grid.Row="0" Padding="14,14,14,10">
      <TextBlock Text="项目管理" FontSize="14" FontWeight="SemiBold"
                 Foreground="{DynamicResource SemiColorText0}"/>
    </Border>

    <Border Grid.Row="1" Padding="14,0,14,12"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SemiColorBorder}">
      <StackPanel Spacing="10">
        <Border CornerRadius="6" Padding="1"
                BorderThickness="1" BorderBrush="{DynamicResource SemiColorBorder}"
                Background="{DynamicResource SemiColorBg0}">
          <Grid ColumnDefinitions="28,*">
            <icons:MaterialIcon Grid.Column="0" Kind="Magnify"
                                Foreground="{DynamicResource SemiColorText2}"
                                VerticalAlignment="Center" HorizontalAlignment="Center"></icons:MaterialIcon>
            <TextBox Grid.Column="1" Text="{Binding SearchText}"
                     PlaceholderText="搜索项目..." FontSize="12"
                     BorderThickness="0" Background="Transparent"/>
          </Grid>
        </Border>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
          <Button Grid.Column="0" Classes="Primary" FontSize="12"
                  Command="{Binding AddServerProjectCommand}"
                  HorizontalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <icons:MaterialIcon Kind="ServerPlus" Foreground="White"></icons:MaterialIcon>
              <TextBlock Text="服务端项目"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="1" FontSize="12"
                  Command="{Binding AddClientProjectCommand}"
                  HorizontalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <icons:MaterialIcon Kind="FolderPlus"
                                  Foreground="{DynamicResource SemiColorText1}"></icons:MaterialIcon>
              <TextBlock Text="客户端项目"/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>

    <ListBox Grid.Row="2"
             ItemsSource="{Binding FilteredProjects}"
             SelectedItem="{Binding SelectedProject}"
             BorderThickness="0" Padding="4,4">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="ml:ProjectConfig">
          <Border CornerRadius="6" Cursor="Hand" MinHeight="60"
                  BorderThickness="1" BorderBrush="Transparent"
                  Margin="4,2" Padding="0" Background="Transparent">
            <Border.Styles>
              <Style Selector="Border:pointerover">
                <Setter Property="BorderBrush" Value="{DynamicResource SemiColorPrimary}"/>
                <Setter Property="Background" Value="{DynamicResource SemiColorFill0}"/>
              </Style>
            </Border.Styles>

            <Grid ColumnDefinitions="36,*,Auto" Margin="10,8">
              <Border Grid.Column="0" CornerRadius="8" Width="34" Height="34"
                      VerticalAlignment="Center"
                      Background="{DynamicResource SemiColorPrimary}">
                <icons:MaterialIcon Kind="PackageVariantClosed" Foreground="White"></icons:MaterialIcon>
              </Border>

              <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Spacing="2">
                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource SemiColorText0}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding LocalPath, TargetNullValue='未设置本地路径'}"
                           FontSize="10" Foreground="{DynamicResource SemiColorText2}"
                           TextTrimming="CharacterEllipsis"/>
              </StackPanel>

              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2"
                          VerticalAlignment="Center">
                <Button Width="26" Height="26" Classes="Tertiary" Padding="0"
                        ToolTip.Tip="上移"
                        Command="{Binding $parent[ListBox].DataContext.MoveUpProjectCommand}"
                        CommandParameter="{Binding}">
                  <icons:MaterialIcon Kind="ChevronUp"
                                      Foreground="{DynamicResource SemiColorText2}"></icons:MaterialIcon>
                </Button>
                <Button Width="26" Height="26" Classes="Tertiary" Padding="0"
                        ToolTip.Tip="下移"
                        Command="{Binding $parent[ListBox].DataContext.MoveDownProjectCommand}"
                        CommandParameter="{Binding}">
                  <icons:MaterialIcon Kind="ChevronDown"
                                      Foreground="{DynamicResource SemiColorText2}"></icons:MaterialIcon>
                </Button>
                <Button Width="26" Height="26" Classes="Tertiary" Padding="0"
                        ToolTip.Tip="删除"
                        Command="{Binding $parent[ListBox].DataContext.RemoveProjectCommand}"
                        CommandParameter="{Binding}">
                  <icons:MaterialIcon Kind="DeleteOutline"
                                      Foreground="{DynamicResource SemiColorDanger}"></icons:MaterialIcon>
                </Button>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>

      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="0"/>
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
      </ListBox.Styles>
    </ListBox>

    <Border Grid.Row="3" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SemiColorBorder}" Padding="14,8">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <icons:MaterialIcon Kind="FolderMultiple"
                            Foreground="{DynamicResource SemiColorText2}"></icons:MaterialIcon>
        <TextBlock FontSize="11" Foreground="{DynamicResource SemiColorText2}">
          <Run Text="共 "/>
          <Run Text="{Binding FilteredProjects.Count}"/>
          <Run Text=" 个项目"/>
        </TextBlock>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
