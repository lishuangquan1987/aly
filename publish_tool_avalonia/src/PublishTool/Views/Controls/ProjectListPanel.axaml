<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:atom="https://atomui.net"
             xmlns:ml="using:PublishTool.Models.Local"
             xmlns:vm="using:PublishTool.ViewModels"
             x:Class="PublishTool.Views.Controls.ProjectListPanel"
             x:DataType="vm:MainWindowViewModel">
  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <Border Grid.Row="0" Padding="12,12,12,4">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="项目管理"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBase}"
                   VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <Border Grid.Row="1" Padding="12,0,12,8">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <atom:TextBox Grid.Column="0"
                        Text="{Binding SearchText}"
                        PlaceholderText="搜索项目名称..." FontSize="12"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
            <atom:Button Content="+ 服务端" ButtonType="Primary"
                          Command="{Binding AddServerProjectCommand}"
                          FontSize="12"/>
            <atom:Button Content="+ 客户端" ButtonType="Default"
                          Command="{Binding AddClientProjectCommand}"
                          FontSize="12"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- 项目列表 -->
    <atom:ListBox Grid.Row="2"
                  ItemsSource="{Binding FilteredProjects}"
                  SelectedItem="{Binding SelectedProject}"
                  BorderThickness="0"
                  Padding="4,0">
      <atom:ListBox.ItemTemplate>
        <DataTemplate x:DataType="ml:ProjectConfig">
          <Border Background="{DynamicResource BgContainer}"
                  CornerRadius="6"
                  Cursor="Hand"
                  MinHeight="56"
                  BorderThickness="1"
                  BorderBrush="Transparent"
                  Margin="4,2"
                  Padding="0">
            <Border.Styles>
              <Style Selector="Border:pointerover">
                <Setter Property="Background" Value="{DynamicResource ControlStrokeColorSecondary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
              </Style>
            </Border.Styles>

            <Grid ColumnDefinitions="36,*,Auto" Margin="8,6,4,6">
              <Border Grid.Column="0"
                      Background="{DynamicResource PrimaryColor}"
                      CornerRadius="6" Width="28" Height="28"
                      VerticalAlignment="Center"
                      Opacity="0.85">
                <Path Data="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
                      Width="14" Height="14" Stretch="Uniform"
                      Fill="White" Margin="7"/>
              </Border>

              <StackPanel Grid.Column="1" Margin="8,0,0,0"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBase}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding LocalPath, TargetNullValue='未设置本地路径'}"
                           FontSize="10"
                           Foreground="{DynamicResource TextTertiary}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,0"/>
              </StackPanel>

              <StackPanel Grid.Column="2"
                          Orientation="Horizontal" Spacing="2"
                          VerticalAlignment="Center" Margin="4,0,0,0">
                <atom:Button Width="28" Height="28" ButtonType="Text"
                             ToolTip.Tip="上移"
                             Command="{Binding $parent[atom:ListBox].DataContext.MoveUpProjectCommand}"
                             CommandParameter="{Binding}" Opacity="0.5">
                  <Path Data="M7 14l5-5 5 5H7z" Width="14" Height="14"
                        Fill="{DynamicResource TextTertiary}"/>
                </atom:Button>
                <atom:Button Width="28" Height="28" ButtonType="Text"
                             ToolTip.Tip="下移"
                             Command="{Binding $parent[atom:ListBox].DataContext.MoveDownProjectCommand}"
                             CommandParameter="{Binding}" Opacity="0.5">
                  <Path Data="M7 10l5 5 5-5H7z" Width="14" Height="14"
                        Fill="{DynamicResource TextTertiary}"/>
                </atom:Button>
                <atom:Button Width="28" Height="28" ButtonType="Text"
                             ToolTip.Tip="删除项目"
                             Command="{Binding $parent[atom:ListBox].DataContext.RemoveProjectCommand}"
                             CommandParameter="{Binding}" Opacity="0.5">
                  <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                        Width="14" Height="14"
                        Fill="{DynamicResource ErrorColor}"/>
                </atom:Button>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </atom:ListBox.ItemTemplate>

      <atom:ListBox.Styles>
        <Style Selector="atom|ListBoxItem">
          <Setter Property="Padding" Value="0"/>
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="atom|ListBoxItem:selected /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="atom|ListBoxItem:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
      </atom:ListBox.Styles>
    </atom:ListBox>

    <!-- 底部统计 -->
    <Border Grid.Row="3" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource BorderColor}"
            Padding="12,6">
      <TextBlock Text="{Binding FilteredProjects.Count, StringFormat='共 {0} 个项目'}"
                 FontSize="11"
                 Foreground="{DynamicResource TextTertiary}"/>
    </Border>
  </Grid>
</UserControl>