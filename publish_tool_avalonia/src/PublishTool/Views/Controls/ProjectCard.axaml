<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ml="using:PublishTool.Models.Local"
             xmlns:vm="using:PublishTool.ViewModels"
             x:Class="PublishTool.Views.Controls.ProjectCard"
             x:DataType="ml:ProjectConfig"
             PointerEntered="CardPointerEnter"
             PointerExited="CardPointerLeave">
  <Border Background="#252525" CornerRadius="4" 
          Cursor="Hand"
          MinHeight="50">
    <Border.Styles>
      <Style Selector="Border">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
      </Style>
      <Style Selector="Border:pointerover">
        <Setter Property="Background" Value="#2d2d2d"/>
        <Setter Property="BorderBrush" Value="#00a8ff"/>
        <Setter Property="BorderThickness" Value="1"/>
      </Style>
    </Border.Styles>
    
    <Grid ColumnDefinitions="32,*,Auto">
      <!-- 图标 -->
      <Border Grid.Column="0" Background="#00a8ff" CornerRadius="4" Margin="8" Padding="4">
        <Path Data="M17 20h4v-2h-4v-3l-4 4h3v2l-4-4v3h4v2z" 
              Width="16" Height="16" Fill="White"/>
      </Border>
      
      <!-- 项目信息 -->
      <StackPanel Grid.Column="1" Margin="0,8">
        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
        <TextBlock Text="{Binding LocalPath, StringFormat='本地: {0}', TargetNullValue='本地: -'}" 
                   FontSize="10" Foreground="#888888" Margin="0,2,0,0"/>
      </StackPanel>
      
      <!-- 操作按钮 -->
      <StackPanel x:Name="ActionButtons" Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="4,0,8,0" VerticalAlignment="Center">
        <Button Width="26" Height="26" 
                Background="#3d3d3d" Foreground="White"
                BorderThickness="0" CornerRadius="3"
                Tag="moveup" Click="ActionButton_Click"
                Opacity="0">
          <Path Data="M7 14l5-5 5 5H7z" Width="14" Height="14"/>
        </Button>
        <Button Width="26" Height="26" 
                Background="#3d3d3d" Foreground="White"
                BorderThickness="0" CornerRadius="3"
                Tag="movedown" Click="ActionButton_Click"
                Opacity="0">
          <Path Data="M7 10l5 5 5-5H7z" Width="14" Height="14"/>
        </Button>
        <Button Width="26" Height="26" 
                Background="#ff4444" Foreground="White"
                BorderThickness="0" CornerRadius="3"
                Tag="delete" Click="ActionButton_Click"
                Opacity="0">
          <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                Width="14" Height="14"/>
        </Button>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>