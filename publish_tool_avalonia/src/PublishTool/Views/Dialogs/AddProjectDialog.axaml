<semi:Window xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:semi="https://irihi.tech/semi"
              xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
              xmlns:vm="using:PublishTool.ViewModels"
              xmlns:m="using:PublishTool.Models"
              x:Class="PublishTool.Views.Dialogs.AddProjectDialog"
              x:DataType="vm:AddProjectDialogViewModel"
              Title="添加客户端项目" Width="520" SizeToContent="Height"
              WindowStartupLocation="CenterOwner">

  <Border Padding="24">
    <StackPanel Spacing="20">
      <StackPanel Spacing="4">
        <TextBlock Text="添加客户端项目" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource SemiColorText0}"/>
        <TextBlock Text="连接到服务端并关联本地项目文件夹" FontSize="12"
                   Foreground="{DynamicResource SemiColorText2}"/>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="服务器地址" FontSize="12" Foreground="{DynamicResource SemiColorText1}"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <Border CornerRadius="6" Padding="1"
                  BorderThickness="1" BorderBrush="{DynamicResource SemiColorBorder}"
                  Background="{DynamicResource SemiColorBg0}">
            <Grid ColumnDefinitions="28,*">
              <icons:MaterialIcon Kind="Server"
                                  Foreground="{DynamicResource SemiColorText2}"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"></icons:MaterialIcon>
              <TextBox Grid.Column="1" Text="{Binding ServerUrl}"
                       PlaceholderText="http://192.168.1.100:8080" FontSize="13"
                       BorderThickness="0" Background="Transparent"/>
            </Grid>
          </Border>
          <Button Grid.Column="1" Classes="Primary" Command="{Binding FetchProjectsCommand}" FontSize="12">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <icons:MaterialIcon Kind="Download" Foreground="White"></icons:MaterialIcon>
              <TextBlock Text="获取项目列表"/>
            </StackPanel>
          </Button>
        </Grid>
        <TextBlock Text="{Binding ServerUrlError}" FontSize="11"
                   Foreground="{DynamicResource SemiColorDanger}"
                   IsVisible="{Binding ServerUrlError, Converter={StaticResource StringNotEmptyConverter}}"/>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="选择项目" FontSize="12" Foreground="{DynamicResource SemiColorText1}"/>
        <ListBox ItemsSource="{Binding AvailableProjects}" SelectedItem="{Binding SelectedProject}"
                 Height="180" BorderThickness="1" BorderBrush="{DynamicResource SemiColorBorder}"
                 CornerRadius="6">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="m:ProjectDto">
              <Border Padding="10,6">
                <StackPanel Spacing="2">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                             Foreground="{DynamicResource SemiColorText0}"/>
                  <TextBlock Text="{Binding Name}" FontSize="11"
                             Foreground="{DynamicResource SemiColorText2}"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="本地文件夹路径" FontSize="12" Foreground="{DynamicResource SemiColorText1}"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <Border CornerRadius="6" Padding="1"
                  BorderThickness="1" BorderBrush="{DynamicResource SemiColorBorder}"
                  Background="{DynamicResource SemiColorBg0}">
            <Grid ColumnDefinitions="28,*">
              <icons:MaterialIcon Kind="Folder"
                                  Foreground="{DynamicResource SemiColorText2}"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"></icons:MaterialIcon>
              <TextBox Grid.Column="1" Text="{Binding LocalPath}"
                       PlaceholderText="D:\Projects\MyApp" FontSize="13"
                       BorderThickness="0" Background="Transparent"/>
            </Grid>
          </Border>
          <Button Grid.Column="1" Click="SelectLocalFolder_Click" FontSize="12">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <icons:MaterialIcon Kind="FolderOpen"
                                  Foreground="{DynamicResource SemiColorText1}"></icons:MaterialIcon>
              <TextBlock Text="浏览..."/>
            </StackPanel>
          </Button>
        </Grid>
        <TextBlock Text="{Binding LocalPathError}" FontSize="11"
                   Foreground="{DynamicResource SemiColorDanger}"
                   IsVisible="{Binding LocalPathError, Converter={StaticResource StringNotEmptyConverter}}"/>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="可执行文件路径（可选）" FontSize="12" Foreground="{DynamicResource SemiColorText1}"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <Border CornerRadius="6" Padding="1"
                  BorderThickness="1" BorderBrush="{DynamicResource SemiColorBorder}"
                  Background="{DynamicResource SemiColorBg0}">
            <Grid ColumnDefinitions="28,*">
              <icons:MaterialIcon Kind="Application"
                                  Foreground="{DynamicResource SemiColorText2}"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"></icons:MaterialIcon>
              <TextBox Grid.Column="1" Text="{Binding ExePath}"
                       PlaceholderText="D:\Projects\MyApp\app.exe" FontSize="13"
                       BorderThickness="0" Background="Transparent"/>
            </Grid>
          </Border>
          <Button Grid.Column="1" Click="SelectExeFile_Click" FontSize="12">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <icons:MaterialIcon Kind="FileSearch"
                                  Foreground="{DynamicResource SemiColorText1}"></icons:MaterialIcon>
              <TextBlock Text="浏览..."/>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>

      <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SemiColorBorder}" Padding="0,16,0,0">
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
          <Button FontSize="13" Click="CancelButton_Click">取消</Button>
          <Button Classes="Primary" FontSize="13" Command="{Binding ConfirmCommand}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <icons:MaterialIcon Kind="Check" Foreground="White"></icons:MaterialIcon>
              <TextBlock Text="确认添加"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</semi:Window>
