<atom:Window xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              xmlns:vm="using:PublishTool.ViewModels"
              x:Class="PublishTool.Views.Dialogs.ProjectSettingsDialog"
              x:DataType="vm:ProjectSettingsDialogViewModel"
              Title="项目设置" Width="400" SizeToContent="Height">
  <StackPanel Spacing="12" Margin="16">
    <atom:TextBox PlaceholderText="显示标题"
                  Text="{Binding Title}"/>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <atom:TextBox Text="{Binding ExePath}"
                    PlaceholderText="EXE 路径" />
      <atom:Button Content="浏览..." Click="SelectExeFile_Click"/>
    </StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <atom:TextBox Text="{Binding LocalPath}"
                    PlaceholderText="本地文件夹路径" />
      <atom:Button Content="浏览..." Click="SelectLocalFolder_Click"/>
    </StackPanel>
    <atom:Button Content="保存"
                 Command="{Binding SaveCommand}"
                 ButtonType="Primary"
                 HorizontalAlignment="Right"/>
  </StackPanel>
</atom:Window>