<atom:Window xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:atom="https://atomui.net"
              xmlns:vm="using:PublishTool.ViewModels"
              x:Class="PublishTool.Views.Dialogs.AddServerProjectDialog"
              x:DataType="vm:AddServerProjectDialogViewModel"
              Title="新建服务端项目" Width="420" SizeToContent="Height"
              WindowStartupLocation="CenterOwner">
  <Border Padding="20">
    <StackPanel Spacing="16">
      <!-- 头部 -->
      <TextBlock Text="新建服务端项目"
                 FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextBase}"/>
      <Rectangle Height="1" Fill="{DynamicResource BorderColor}"/>

      <!-- 表单 -->
      <StackPanel Spacing="12">
        <StackPanel Spacing="4">
          <TextBlock Text="服务器地址" FontSize="11"
                     Foreground="{DynamicResource TextSecondary}"/>
          <atom:TextBox Text="{Binding ServerUrl}"
                        PlaceholderText="http://192.168.1.100:8080"
                        FontSize="12"/>
          <TextBlock Text="{Binding ServerUrlError}"
                     FontSize="10" Foreground="{DynamicResource ErrorColor}"
                     IsVisible="{Binding ServerUrlError, Converter={StaticResource StringNotEmptyConverter}}"/>
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="项目名称" FontSize="11"
                     Foreground="{DynamicResource TextSecondary}"/>
          <atom:TextBox Text="{Binding Name}"
                        PlaceholderText="my-project"
                        FontSize="12"/>
          <TextBlock Text="{Binding NameError}"
                     FontSize="10" Foreground="{DynamicResource ErrorColor}"
                     IsVisible="{Binding NameError, Converter={StaticResource StringNotEmptyConverter}}"/>
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="显示标题" FontSize="11"
                     Foreground="{DynamicResource TextSecondary}"/>
          <atom:TextBox Text="{Binding Title}"
                        PlaceholderText="我的项目"
                        FontSize="12"/>
          <TextBlock Text="{Binding TitleError}"
                     FontSize="10" Foreground="{DynamicResource ErrorColor}"
                     IsVisible="{Binding TitleError, Converter={StaticResource StringNotEmptyConverter}}"/>
        </StackPanel>
        <atom:CheckBox Content="强制更新"
                       IsChecked="{Binding IsForceUpdate}"
                       FontSize="12"/>
        <TextBlock Text="{Binding StatusMessage}"
                   FontSize="11" Foreground="{DynamicResource ErrorColor}"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"/>
      </StackPanel>

      <!-- 操作按钮 -->
      <StackPanel Orientation="Horizontal" Spacing="8"
                  HorizontalAlignment="Right">
        <atom:Button Content="取消" ButtonType="Default" FontSize="12" Click="CancelButton_Click"/>
        <atom:Button Content="创建项目" ButtonType="Primary"
                     Command="{Binding CreateCommand}"
                     IsEnabled="{Binding !IsCreating}" FontSize="12"/>
      </StackPanel>
    </StackPanel>
  </Border>
</atom:Window>