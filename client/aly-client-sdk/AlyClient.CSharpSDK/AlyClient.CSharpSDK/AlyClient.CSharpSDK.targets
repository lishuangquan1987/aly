<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    AlyClient.CSharpSDK: deploy runtime files to ../UpdateFolder/

    aly-client.exe is downloaded from GitHub Releases on first build.
    client.json is auto-generated with a default template.
  -->

  <PropertyGroup>
    <AlyUpdateFolder Condition="'$(AlyUpdateFolder)' == ''">$(OutDir)..\UpdateFolder\</AlyUpdateFolder>
    <AlyClientVersion Condition="'$(AlyClientVersion)' == ''">ALY_CLIENT_VERSION_PLACEHOLDER</AlyClientVersion>
    <AlyClientDownloadUrl Condition="'$(AlyClientDownloadUrl)' == ''">https://github.com/lishuangquan1987/aly/releases/download/v$(AlyClientVersion)/aly-client.exe</AlyClientDownloadUrl>
  </PropertyGroup>

  <Target Name="AlyDeployToUpdateFolder" BeforeTargets="Build">

    <MakeDir Directories="$(AlyUpdateFolder)" />

    <!-- Download aly-client.exe from GitHub Releases if not present -->
    <Exec Condition="!Exists('$(AlyUpdateFolder)aly-client.exe')"
          Command="powershell -NoProfile -Command &quot;
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12;
try {
  Invoke-WebRequest -Uri '$(AlyClientDownloadUrl)' -OutFile '$(AlyUpdateFolder)aly-client.exe' -ErrorAction Stop;
  Write-Host 'Downloaded aly-client.exe v$(AlyClientVersion) successfully';
} catch {
  Write-Error &quot;Failed to download aly-client.exe: $($_.Exception.Message)&quot;;
  exit 1;
}&quot;" />

    <!-- Generate default client.json if missing -->
    <WriteLinesToFile Condition="!Exists('$(AlyUpdateFolder)client.json')"
                      File="$(AlyUpdateFolder)client.json"
                      Lines="{&quot;main_exe_relative_path&quot;: &quot;../ApplicationFolder/YourApp.exe&quot;,&quot;must_close_process_name&quot;: [&quot;YourApp&quot;]}"
                      Overwrite="true" />

  </Target>

</Project>
